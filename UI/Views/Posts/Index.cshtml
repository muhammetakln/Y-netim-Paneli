@model IEnumerable<Core.Concrete.DTOs.PostListItemDto>

@{
    ViewBag.Title = "Index";
}
<div class="card">
    <div class="card-header">
        <h2>Post List</h2>
        <p>
            <a href="@Url.Action("create","posts")" class="btn btn-outline-primary btn-sm">Create New</a>
        </p>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.ShortContent)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.CoverImageUrl)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.PublishDate)
                </th>
                <th></th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ShortContent)
                    </td>
                    <td>
                        <img src="@item.CoverImageUrl" alt="@item.Title" class="img-thumbnail" width="100" />
                    </td>
                    <td>
                        @item.PublishDate.ToLongDateString()
                    </td>
                    <td>
                        @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                        @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                        @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                    </td>
                </tr>
            }

        </table>
    </div>
</div>