@model UI.Models.RegisterViewModel

@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<h4 class="mb-2">Adventure starts here 🚀</h4>
<p class="mb-4">Make your app management easy and fun!</p>

@using (Html.BeginForm("register", "account", FormMethod.Post, new { @class = "mb-3", @id = "formAuthentication" }))
{
    <div class="mb-3">
        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
        @Html.EditorFor(m => m.Email, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter your email", @autofocus = true } })
        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3 form-password-toggle">
        <div class="d-flex justify-content-between">
            @Html.LabelFor(m => m.Password, new { @class = "form-label" })
        </div>
        <div class="input-group input-group-merge">
            @Html.EditorFor(m => m.Password, new { htmlAttributes = new { @class = "form-control", @placeholder = "************" } })
            <span class="input-group-text cursor-pointer"><i class="bx bx-hide"></i></span>
        </div>
        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3 form-password-toggle">
        <div class="d-flex justify-content-between">
            @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label" })
        </div>
        <div class="input-group input-group-merge">
            @Html.EditorFor(m => m.ConfirmPassword, new { htmlAttributes = new { @class = "form-control", @placeholder = "************" } })
            <span class="input-group-text cursor-pointer"><i class="bx bx-hide"></i></span>
        </div>
        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        <button class="btn btn-primary d-grid w-100" type="submit">Sign up</button>
        @Html.AntiForgeryToken()
    </div>
}

<p class="text-center">
    <span>Already have an account?</span>
    <a href="@Url.Action("login","account")">
        <span>Sign in instead</span>
    </a>
</p>
