@model UI.Models.LoginViewModel

@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<h4 class="mb-2">Welcome to Sneat! 👋</h4>
<p class="mb-4">Please sign-in to your account and start the adventure</p>

@using (Html.BeginForm("login", "account", FormMethod.Post, new { @class = "mb-3", @id = "formAuthentication" }))
{
    <div class="mb-3">
        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
        @Html.EditorFor(m => m.Email, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter your email", @autofocus = true } })
        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3 form-password-toggle">
        <div class="d-flex justify-content-between">
            @Html.LabelFor(m => m.Password, new { @class = "form-label" })
            <a href="@Url.Action("forgotpassword","account")">
                <small>Forgot Password?</small>
            </a>
        </div>
        <div class="input-group input-group-merge">
            @Html.EditorFor(m => m.Password, new { htmlAttributes = new { @class = "form-control", @placeholder = "************" } })
            <span class="input-group-text cursor-pointer"><i class="bx bx-hide"></i></span>
        </div>
        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        <div class="form-check">
            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
            @Html.LabelFor(m => m.RememberMe, new { @class = "form-check-label" })
        </div>
    </div>
    <div class="mb-3">
        <button class="btn btn-primary d-grid w-100" type="submit">Sign in</button>
        @Html.AntiForgeryToken()
    </div>
}

<p class="text-center">
    <span>New on our platform?</span>
    <a href="@Url.Action("register","account")">
        <span>Create an account</span>
    </a>
</p>
