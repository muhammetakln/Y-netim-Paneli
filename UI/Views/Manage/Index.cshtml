@model UI.Models.IndexViewModel
@{
    ViewBag.Title = "Settings";
    var activeTab = Request.QueryString["tab"] ?? "account";
}

<h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Hesap Ayarları /</span> Profil</h4>

<div class="row">
    <div class="col-md-12">
        <!-- Sekmeler -->
        <ul class="nav nav-pills flex-column flex-md-row mb-3">
            <li class="nav-item">
                <a class="nav-link @(activeTab == "account" ? "active" : "")" href="?tab=account">
                    <i class="bx bx-user me-1"></i> Profil
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "settings" ? "active" : "")" href="?tab=settings">
                    <i class="bx bx-cog me-1"></i> Ayarlar
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "security" ? "active" : "")" href="?tab=security">
                    <i class="bx bx-lock-alt me-1"></i> Güvenlik
                </a>
            </li>
        </ul>

        <!-- Profil Sekmesi -->
        @if (activeTab == "account")
        {
            <div class="card mb-4">
                <h5 class="card-header">Profil Detayları</h5>
                <div class="card-body">
                    <div class="d-flex align-items-start align-items-sm-center gap-4">
                        <img src="~/assets/img/avatars/1.png" alt="user-avatar" class="d-block rounded" height="100" width="100" id="uploadedAvatar" />
                        <div class="button-wrapper">
                            <label for="upload" class="btn btn-primary me-2 mb-4" tabindex="0">
                                <span class="d-none d-sm-block">Yeni Fotoğraf Yükle</span>
                                <i class="bx bx-upload d-block d-sm-none"></i>
                                <input type="file" id="upload" class="account-file-input" hidden accept="image/png, image/jpeg" />
                            </label>
                            <button type="button" class="btn btn-outline-secondary account-image-reset mb-4">
                                <i class="bx bx-reset d-block d-sm-none"></i>
                                <span class="d-none d-sm-block">Sıfırla</span>
                            </button>
                            <p class="text-muted mb-0">JPG, GIF veya PNG. Maks 800KB</p>
                        </div>
                    </div>
                </div>
                <hr class="my-0" />
                <div class="card-body">
                    <form id="formAccountSettings" method="POST">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="mb-3 col-md-6">
                                <label for="firstName" class="form-label">Ad</label>
                                <input class="form-control" type="text" id="firstName" name="firstName" value="@User.Identity.Name" autofocus />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="lastName" class="form-label">Soyad</label>
                                <input class="form-control" type="text" name="lastName" id="lastName" value="" />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="email" class="form-label">E-mail</label>
                                <input class="form-control" type="text" id="email" name="email" value="@User.Identity.Name" placeholder="email@example.com" />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="organization" class="form-label">Organizasyon</label>
                                <input type="text" class="form-control" id="organization" name="organization" value="" />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label class="form-label" for="phoneNumber">Telefon</label>
                                <div class="input-group input-group-merge">
                                    <span class="input-group-text">TR (+90)</span>
                                    <input type="text" id="phoneNumber" name="phoneNumber" class="form-control" placeholder="555 555 55 55" />
                                </div>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="address" class="form-label">Adres</label>
                                <input type="text" class="form-control" id="address" name="address" placeholder="Adres" />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="state" class="form-label">Şehir</label>
                                <input class="form-control" type="text" id="state" name="state" placeholder="İstanbul" />
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="zipCode" class="form-label">Posta Kodu</label>
                                <input type="text" class="form-control" id="zipCode" name="zipCode" placeholder="34000" maxlength="5" />
                            </div>
                        </div>
                        <div class="mt-2">
                            <button type="submit" class="btn btn-primary me-2">Değişiklikleri Kaydet</button>
                            <button type="reset" class="btn btn-outline-secondary">İptal</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <h5 class="card-header">Hesabı Sil</h5>
                <div class="card-body">
                    <div class="mb-3 col-12 mb-0">
                        <div class="alert alert-warning">
                            <h6 class="alert-heading fw-bold mb-1">Hesabınızı silmek istediğinizden emin misiniz?</h6>
                            <p class="mb-0">Hesabınızı sildikten sonra geri dönüş yoktur. Lütfen emin olun.</p>
                        </div>
                    </div>
                    <form id="formAccountDeactivation">
                        @Html.AntiForgeryToken()
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="accountActivation" id="accountActivation" />
                            <label class="form-check-label" for="accountActivation">Hesap silme işlemini onaylıyorum</label>
                        </div>
                        <button type="submit" class="btn btn-danger deactivate-account">Hesabı Devre Dışı Bırak</button>
                    </form>
                </div>
            </div>
        }

        <!-- Ayarlar Sekmesi -->
        @if (activeTab == "settings")
        {
            <div class="card mb-4">
                <h5 class="card-header">Genel Ayarlar</h5>
                <div class="card-body">
                    <form>
                        @Html.AntiForgeryToken()

                        <!-- Dil -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="language">Dil</label>
                            <div class="col-sm-9">
                                <select id="language" class="form-select">
                                    <option value="tr" selected>Türkçe</option>
                                    <option value="en">English</option>
                                    <option value="de">Deutsch</option>
                                    <option value="fr">Français</option>
                                </select>
                            </div>
                        </div>

                        <!-- Saat Dilimi -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="timezone">Saat Dilimi</label>
                            <div class="col-sm-9">
                                <select id="timezone" class="form-select">
                                    <option value="Europe/Istanbul" selected>(GMT+03:00) İstanbul</option>
                                    <option value="Europe/London">(GMT+00:00) Londra</option>
                                    <option value="America/New_York">(GMT-05:00) New York</option>
                                    <option value="Asia/Tokyo">(GMT+09:00) Tokyo</option>
                                </select>
                            </div>
                        </div>

                        <!-- Para Birimi -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="currency">Para Birimi</label>
                            <div class="col-sm-9">
                                <select id="currency" class="form-select">
                                    <option value="try" selected>TRY (₺)</option>
                                    <option value="usd">USD ($)</option>
                                    <option value="eur">EUR (€)</option>
                                    <option value="gbp">GBP (£)</option>
                                </select>
                            </div>
                        </div>

                        <!-- Tema -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Tema</label>
                            <div class="col-sm-9">
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="theme" id="themeLight" value="light" checked>
                                    <label class="form-check-label" for="themeLight">Açık</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="theme" id="themeDark" value="dark">
                                    <label class="form-check-label" for="themeDark">Koyu</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="theme" id="themeAuto" value="auto">
                                    <label class="form-check-label" for="themeAuto">Otomatik</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-9 offset-sm-3">
                                <button type="submit" class="btn btn-primary me-2">Kaydet</button>
                                <button type="reset" class="btn btn-outline-secondary">İptal</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Bildirim Ayarları -->
            <div class="card mb-4">
                <h5 class="card-header">Bildirim Ayarları</h5>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="emailNotifications" checked>
                            <label class="form-check-label" for="emailNotifications">E-posta Bildirimleri</label>
                        </div>
                        <small class="text-muted">Önemli güncellemeler için e-posta alın</small>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="smsNotifications">
                            <label class="form-check-label" for="smsNotifications">SMS Bildirimleri</label>
                        </div>
                        <small class="text-muted">Kritik olaylar için SMS alın</small>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="pushNotifications" checked>
                            <label class="form-check-label" for="pushNotifications">Push Bildirimleri</label>
                        </div>
                        <small class="text-muted">Tarayıcı bildirimleri alın</small>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="marketingEmails">
                            <label class="form-check-label" for="marketingEmails">Pazarlama E-postaları</label>
                        </div>
                        <small class="text-muted">Yeni özellikler ve kampanyalar hakkında bilgi alın</small>
                    </div>

                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        }

        <!-- Güvenlik Sekmesi -->
        @if (activeTab == "security")
        {
            <div class="card mb-4">
                <h5 class="card-header">Şifre Değiştir</h5>
                <div class="card-body">
                    <form>
                        @Html.AntiForgeryToken()
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="currentPassword">Mevcut Şifre</label>
                            <div class="col-sm-9">
                                <input type="password" class="form-control" id="currentPassword" placeholder="••••••••">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="newPassword">Yeni Şifre</label>
                            <div class="col-sm-9">
                                <input type="password" class="form-control" id="newPassword" placeholder="••••••••">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" for="confirmPassword">Şifreyi Onayla</label>
                            <div class="col-sm-9">
                                <input type="password" class="form-control" id="confirmPassword" placeholder="••••••••">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-9 offset-sm-3">
                                <button type="submit" class="btn btn-primary me-2">Şifreyi Güncelle</button>
                                <button type="reset" class="btn btn-outline-secondary">İptal</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- İki Faktörlü Doğrulama -->
            <div class="card mb-4">
                <h5 class="card-header">İki Faktörlü Doğrulama (2FA)</h5>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="twoFactorAuth">
                            <label class="form-check-label" for="twoFactorAuth">İki Faktörlü Doğrulamayı Etkinleştir</label>
                        </div>
                        <small class="text-muted">Hesabınıza ekstra güvenlik katmanı ekleyin</small>
                    </div>
                    <button type="button" class="btn btn-primary">Etkinleştir</button>
                </div>
            </div>

            <!-- Oturum Geçmişi -->
            <div class="card">
                <h5 class="card-header">Son Oturum Açma İşlemleri</h5>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th>Tarayıcı</th>
                                    <th>IP Adresi</th>
                                    <th>Tarih</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i class="bx bxl-chrome me-2"></i> Chrome (Windows)</td>
                                    <td>192.168.1.1</td>
                                    <td>@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><span class="badge bg-success">Aktif</span></td>
                                </tr>
                                <tr>
                                    <td><i class="bx bxl-firefox me-2"></i> Firefox (Linux)</td>
                                    <td>192.168.1.2</td>
                                    <td>@DateTime.Now.AddHours(-2).ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><button class="btn btn-sm btn-outline-danger">Sonlandır</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
